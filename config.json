{
  "target": {
    "process_name": "NRC-Win64-Shipping.exe",
    "window_title_contains": "",
    "bring_to_front": true
  },
  "runtime": {
    "idle_poll_seconds": 0.2,
    "cycle_delay_seconds": 0.0
  },
  "safety": {
    "mouse_corner_stop": true,
    "corner_size": 5
  },
  "hotkeys": {
    "toggle": "f8",
    "reload": "f9",
    "exit": "f10"
  },
  "workflow": {
    "path": "flow.txt",
    "default_between_seconds": 0.5
  },
  "defaults": {
    "mouse_click": {
      "position": "center",
      "button": "left",
      "repeat": 1,
      "repeat_interval_seconds": 0.05,
      "relative_to_window": false
    },
    "mouse_hold": {
      "position": "center",
      "button": "left",
      "hold_seconds": 0.02,
      "repeat": 1,
      "repeat_interval_seconds": 0.05,
      "relative_to_window": false
    },
    "mouse_drag": {
      "position": "center",
      "button": "left",
      "duration_seconds": 0.5,
      "steps": 20,
      "dx_ratio": 0.0,
      "dy_ratio": 0.5,
      "repeat": 1,
      "repeat_interval_seconds": 0.05,
      "relative_to_window": false
    },
    "key_tap": {
      "key": "p",
      "hold_seconds": 0.03,
      "repeat": 1,
      "repeat_interval_seconds": 0.05
    },
    "wait": {
      "seconds": 1.0
    },
    "wait_until_pixel": {
      "tolerance": 10,
      "check_interval_seconds": 0.2,
      "relative_to_window": false
    },
    "wait_until_image": {
      "confidence": 0.9,
      "check_interval_seconds": 0.3,
      "grayscale": true,
      "relative_to_window": false
    }
  }
}
